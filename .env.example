# Core Django settings
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
PUBLIC_BASE_URL=http://localhost:8000

# Secret portal path. Do not use "admin" in production.
ADMIN_PORTAL_SLUG=admin-buec-7c91e4f2
PORTAL_SUPERUSER_ONLY=true

# Database. Leave DATABASE_URL empty for SQLite in local development.
DATABASE_URL=
POSTGRES_DB=buec_documents
POSTGRES_USER=buec
POSTGRES_PASSWORD=replace-with-a-strong-url-safe-password

# Shared Redis is recommended when running more than one web process.
REDIS_URL=

# Email. Console backend is useful locally.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=BUEC Document Team <documents@example.com>
EMAIL_REPLY_TO=info@example.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=20

# Brand and support details
BRAND_NAME=British University Educational Consultancy
BRAND_SHORT_NAME=BUEC
SUPPORT_EMAIL=info@example.com
SUPPORT_PHONE=+44 0000 000000

# Document workflow
UPLOAD_TOKEN_LIFETIME_DAYS=14
MAX_UPLOAD_SIZE_MB=20
DOCUMENT_RETENTION_DAYS=90

# Only enable this when a trusted reverse proxy overwrites X-Real-IP.
TRUST_X_REAL_IP=false

# Optional ClamAV daemon. Set REQUIRE_MALWARE_SCAN=true to fail closed.
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_UNIX_SOCKET=
CLAMAV_TIMEOUT=20
REQUIRE_MALWARE_SCAN=false

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Multiple comma-separated keys are supported; the first key encrypts new files.
FILE_ENCRYPTION_KEYS=
PRIVATE_UPLOAD_ROOT=/app/private_uploads

# Production-only hardening
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false
